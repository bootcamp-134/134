generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IncomeLevel {
  LOW
  MIDDLE
  HIGH
}

enum CookingSkill {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  profile      UserProfile?
  chatSessions RecipeChatSession[]
  feedPosts    FeedPost[]
}

model UserProfile {
  id                   String       @id @default(cuid())
  userId               String       @unique
  fullName             String
  ageRange             String?
  householdSize        Int
  incomeLevel          IncomeLevel
  weeklyFoodBudget     Int?
  dietPreferences      String[]
  allergens            String[]
  dislikedIngredients  String[]
  cookingSkill         CookingSkill
  availableEquipment   String[]
  shoppingFrequency    String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ingredient {
  id                String             @id @default(cuid())
  name              String             @unique
  normalizedName    String             @unique
  defaultPrice      Int                @default(0)
  recipeIngredients RecipeIngredient[]
}

model Recipe {
  id                  String             @id @default(cuid())
  title               String
  description         String
  servings            Int
  cookingMinutes      Int
  difficulty          String
  estimatedTotalCost  Int
  tags                String[]
  allergens           String[]
  calories            Int?
  proteinGrams        Int?
  carbGrams           Int?
  fatGrams            Int?
  steps               RecipeStep[]
  ingredients         RecipeIngredient[]
  chatSessions        RecipeChatSession[]
  feedPosts           FeedPost[]
}

model RecipeIngredient {
  id           String     @id @default(cuid())
  recipeId     String
  ingredientId String
  amount       String
  isOptional   Boolean    @default(false)
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
}

model RecipeStep {
  id       String @id @default(cuid())
  recipeId String
  order    Int
  text     String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model RecipeChatSession {
  id        String              @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe              @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  messages  RecipeChatMessage[]
}

model RecipeChatMessage {
  id        String            @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime          @default(now())
  session   RecipeChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model FeedPost {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  imageUrl  String
  comment   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

